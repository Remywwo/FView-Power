{
  "name": "fview-power",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "description": "FView Power — a minimal file previewer & editor for Markdown, PDF, TXT, code, HTML, and images",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
